{% macro recommendationCard(rec) %}
  <article class="app-recommendation-card">

 

    <div class="app-recommendation-card__body">

      <dl class="govuk-summary-list govuk-!-margin-bottom-0">

        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Type</dt>
          <dd class="govuk-summary-list__value">{{ rec.type }}</dd>
        </div>

        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Outcome</dt>
          <dd class="govuk-summary-list__value">{{ rec.outcome }}</dd>
        </div>

        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Associated risk</dt>
          <dd class="govuk-summary-list__value">
            <strong>{{ rec.riskId }}</strong> — {{ rec.risk }}
          </dd>
        </div>

        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Reviewer recommendation</dt>
          <dd class="govuk-summary-list__value">{{ rec.recommendation }}</dd>
        </div>

        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Reviewed recommendation and risk</dt>
          <dd class="govuk-summary-list__value">{{ rec.reviewed }}</dd>
        </div>

        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Status</dt>
          <dd class="govuk-summary-list__value">
            {% if rec.status == "Action added" %}
              <strong class="govuk-tag govuk-tag--blue">
                {{ rec.status }}
              </strong>
            {% else %}
              <strong class="govuk-tag govuk-tag--grey">
                {{ rec.status }}
              </strong>
            {% endif %}
          </dd>
        </div>

        {% if rec.action %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Action</dt>
            <dd class="govuk-summary-list__value">{{ rec.action }}</dd>
          </div>
        {% endif %}

        {% if rec.owner %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Owner</dt>
            <dd class="govuk-summary-list__value">{{ rec.owner }}</dd>
          </div>
        {% endif %}

        {% if rec.resourcesAvailable %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Resources available</dt>
            <dd class="govuk-summary-list__value">{{ rec.resourcesAvailable }}</dd>
          </div>
        {% endif %}

        {% if rec.budgetApproved %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Budget approved</dt>
            <dd class="govuk-summary-list__value">{{ rec.budgetApproved }}</dd>
          </div>
        {% endif %}

        {% if rec.targetDate %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Estimated target completion date</dt>
            <dd class="govuk-summary-list__value">{{ rec.targetDate }}</dd>
          </div>
        {% endif %}

        {% if rec.noTargetDateReason %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Reason no target date given</dt>
            <dd class="govuk-summary-list__value">{{ rec.noTargetDateReason }}</dd>
          </div>
        {% endif %}

        {% if rec.reason %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Reason for no action</dt>
            <dd class="govuk-summary-list__value">{{ rec.reason }}</dd>
          </div>
        {% endif %}

      </dl>

    </div>

  </article>
{% endmacro %}

<style>
  .app-report-header {
    background: #1d70b8;
    color: #ffffff;
    padding: 35px 30px 30px;
    margin-bottom: 30px;
  }

  .app-report-header .govuk-caption-l,
  .app-report-header .govuk-heading-xl,
  .app-report-header .govuk-body-l,
  .app-report-header .govuk-summary-list__key,
