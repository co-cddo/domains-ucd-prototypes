{% extends "layouts/peer-review.html" %}

{% block pageTitle %}
  A1.a – Board direction - Add recommendation
{% endblock %}

{% block beforeContent %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
  {{ govukPhaseBanner({
    tag: {
    text: "prototype",
    classes: "govuk-tag--pink"
    },
      html: 'This is not a full service. It is not production code and you might experience problems.'
  }) }}

    {{ govukBreadcrumbs({
    items: [
      {
        text: "My account",
        href: "/webcaf/peer-review/v1/my-account"
      },
      {
        text: "Edit draft review",
        href: "/webcaf/peer-review/v1/draft-review"
      },
      {
        text: "Objective A - Managing security risk",
        href: "#"
      },
      {
        text: "Add recommendations for A3.a – Asset management
        "
      }
    ]
  }) }}
  <div class="proto-admin">
    <p id="progress-pages"><strong>You have completed 26% of your review</strong></p>
      <div class="progress-inactive">
        <div class="progress-active" style="width: 26%">
        </div>
      </div>
  </div>
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
<div class="govuk-grid-column-two-thirds">

<span class="govuk-caption-l">A3.a – Asset management</span>
<h1 class="govuk-heading-l">Add recommendations </h1>

<p class="govuk-body">
Each recommendation must be recorded separately. If you make more than one recommendation, select ‘Add another recommendation’.
<br><br>
Where appropriate, you should use language from the relevant IGP(s).
</p>
<p>Use <a href='https://www.security.gov.uk/policy-and-guidance/govassure/stage-4-independent-assurance-peer-review/current/' class="govuk-link--no-visited-state">stage 4 guidance (opens in new tab)</a> to support you.</p>

<form id="rec-form" action="/webcaf/peer-review/v1/task/recommendations/check-a3-a" method="post">

  <div id="recommendation-list"></div>

  <button class="govuk-button govuk-button--secondary" type="button" id="add-rec-btn">
    Add another recommendation
  </button>

  <div class="govuk-button-group govuk-!-margin-top-6">
    {{ govukButton({ text: "Continue" }) }}
  </div>

</form>

</div>
</div>
 

<script>
const OUTCOME = "A1-a"; // storage key for this outcome

const list = document.getElementById("recommendation-list");
const addBtn = document.getElementById("add-rec-btn");
let index = 0;

// Load existing recs from session
const saved = JSON.parse(sessionStorage.getItem(`recs-${OUTCOME}`) || "[]");

function addRecommendation(detail = "") {
  index++;
  const block = document.createElement("div");
  block.classList.add("recommendation-item");
  block.dataset.index = index;

  block.innerHTML = `
    <h2 class="govuk-heading-m">Recommendation ${index}</h2>
   



    <div class="govuk-form-group govuk-character-count">  
      <label class="govuk-label" for="rec-detail-${index}"></label>
      <textarea class="govuk-textarea" id="rec-detail-${index}"
                name="rec-detail-${index}" rows="5">${detail}</textarea>
                <div id="word-count-info" class="govuk-hint govuk-character-count__message">
    You can enter up to 100 words
  </div>
    </div>


 
    <button type="button" class="govuk-button govuk-button--secondary remove-rec"
            data-index="${index}" >
      Remove
    </button>

    <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">
  `;

  list.appendChild(block);
}

// Load pre-existing recommendations if any
saved.forEach(r => addRecommendation(r.title, r.detail));
if (saved.length === 0) addRecommendation();

// Add new recommendation
addBtn.addEventListener("click", () => addRecommendation());

// Remove recommendation
list.addEventListener("click", e => {
  if (e.target.classList.contains("remove-rec")) {
    e.preventDefault();
    e.target.closest(".recommendation-item").remove();
  }
});

// Save to sessionStorage on submit
document.getElementById("rec-form").addEventListener("submit", () => {
  const items = document.querySelectorAll(".recommendation-item");
  const recs = [];

  items.forEach(item => {
    const idx = item.dataset.index;
    
    const detail = document.getElementById(`rec-detail-${idx}`).value;
    if (detail) recs.push({ detail });
  });

  sessionStorage.setItem(`recs-${OUTCOME}`, JSON.stringify(recs));
});
</script>

{% endblock %}
