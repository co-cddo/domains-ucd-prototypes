     <h2 class="govuk-heading-m govuk-!-margin-top-6">Create a new report version</h2>

    <p class="govuk-body">
      To create a new version of the report you must <strong>re-open the current review</strong> and make the changes you need.
      You will be able to change outcome statuses, recommendations and comments.
    </p>
  {{ govukInsetText({
  html: 'You can mark one version as the final report. This is the version you should share as xxxxxxxxxxxx.   
</p>'
}) }}
<p class="govuk-body">


    <form action="/webcaf/review/current/task/9/reopen-review" method="post">
      
     <div class="govuk-button-group">
      {{ govukButton({
