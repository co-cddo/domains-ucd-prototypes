        { text: "Generated by" },
        { text: "Status" },
        { text: "Actions" }
      ],
      rows: reportVersions | default([]) | map("toRow")
    }) }}
#}
    



    <p class="govuk-body">
      <a href="/webcaf/review/current/my-account2" class="govuk-link">Return to My account</a>
    </p>


  </div>
</div>
{% endblock %}
