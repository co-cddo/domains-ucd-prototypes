{% extends "/layouts/review-v4.html" %}

{% block pageTitle %}
Report history – Independent Assurance Review
{% endblock %}

{% block beforeContent %}
  {% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

  {{ govukPhaseBanner({
    tag: {
      text: "prototype",
      classes: "govuk-tag--pink"
    },
    html: "This is not a full service. It is not production code and you might experience problems."
  }) }}

  {{ govukBreadcrumbs({
    items: [
      {
        text: "My account",
        href: "/webcaf/review/current/my-account2"
      },
      {
        text: "Report history"
      }
    ]
  }) }}
{% endblock %}

{% block content %}


<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">
  {{ govukNotificationBanner({
  type: "success",
  text: "Final report updated. Version 3 is now the final report."
}) }}

    <span class="govuk-caption-l">SYS-0001 Microsoft CS version 3 (CAF24092025FDMH)</span>
    <h1 class="govuk-heading-l">Report history</h1>

    
    <p class="govuk-body">
    Use this page to manage your IAR reports. Download the final report or browse the version history below.
      
    </p>
    
    {% from "govuk/components/table/macro.njk" import govukTable %}
<div class="govuk-inset-text">
  <p class="govuk-body govuk-!-margin-bottom-1">
    <strong>Final report:</strong> Version 3 (5 March 2026 at 10:15)
  </p>
  <p class="govuk-body govuk-!-margin-bottom-0">
    <a class="govuk-link" href="#">View final report</a> |
    <a class="govuk-link" href="#">Download (PDF)</a> |
    <a class="govuk-link" href="#">Download (XLS)</a> |
    <a class="govuk-link" href="/webcaf/review/current/task/9/choose-final">Change final version</a>
  </p>
</div>


    {{ govukTable({
      caption: "Created versions",
      captionClasses: "govuk-table__caption--m",
      firstCellIsHeader: false,
      head: [
        { text: "Version" },
        { text: "Created on" },
        { text: "Created by Reviewer" },
        { text: "Status" },
        { text: "Actions" }
      ],
      rows: [
        
        [
          { text: "Version 3" },
          { text: "5 March 2026 at 10:15" },
          { text: "Alex Morgan" },
          { html: "<strong class='govuk-tag govuk-tag--blue'>Final</strong>" },
          {
            html:
              "<a class='govuk-link' href='iar-report-v4'>View report</a><br>" +
              "<a class='govuk-link' href='#'>Download (PDF)</a>" 
              
          }
        ],
        [
          { text: "Version 2" },
          { text: "5 December 2025 at 10:15" },
          { text: "Alex Morgan" },
          { html: "<strong class='govuk-tag govuk-tag--grey'>Superseded</strong>" },
          {
            html:
              "<a class='govuk-link' href='#'>View report</a><br>" +
              "<a class='govuk-link' href='#'>Download (PDF)</a>"
          }
        ],
        [
          { text: "Version 1" },
          { text: "26 November 2025 at 16:03" },
          { text: "Alex Morgan" },
          { html: "<strong class='govuk-tag govuk-tag--grey'>Superseded</strong>" },
          {
            html:
              "<a class='govuk-link' href='#'>View report</a><br>" +
              "<a class='govuk-link' href='#'>Download (PDF)</a>"
          }
        ]
      ]
    }) }}

