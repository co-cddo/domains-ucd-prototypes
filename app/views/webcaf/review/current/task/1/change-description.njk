{% extends "/layouts/review.html" %}

{% block pageTitle %}
Change system description
{% endblock %}
 
{% block beforeContent %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
  {{ govukPhaseBanner({
    tag: {
    text: "prototype",
    classes: "govuk-tag--pink"
    },
      html: 'This is not a full service. It is not production code and you might experience problems.'
  }) }}

  
{{ govukBackLink({ href: "/webcaf/review/current/task/1/system-summary", text: "Back" }) }} 
<div class="proto-admin">
 <p id="progress-pages"><strong>You have completed 3% of your review</strong></p>
  <div class="progress-inactive">
    <div class="progress-active" style="width: 3%">
    </div>
  </div>
</div>
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
<div class="govuk-grid-column-two-thirds">
<span class="govuk-caption-l">Microsoft CS version 3 (CAF24092025FDMH)</span>
<h1 class="govuk-heading-l">Change system description</h1>

<form action="/webcaf/review/current/task/1/system-summary" method="post">

  
{{ govukRadios({
  classes: "govuk-radios",
  name: "systype",
  fieldset: {
    legend: {
      text: "What does this system do?",
      isPageHeading: false,
      classes: "govuk-fieldset__legend--m"
    }
  },
  hint: {
    text: "Select one option" 
  },
  items: [
    {
      value: "It directly delivers public services",
      text: "It directly delivers public services",
      checked: true
    },
    {
      value: "It provides core infrastructure essential for other critical systems to function",
      text: "It provides core infrastructure essential for other critical systems to function",
      checked: checked("systype", "It provides core infrastructure essential for other critical systems to function")
    },
    {
      value: "It provides corporate services or functions required for day-to-day operations
              for example, payroll",
      text: "It provides corporate services or functions required for day-to-day operations
              for example, payroll",
      checked: checked("systype", "It provides corporate services or functions required for day-to-day operations
              for example, payroll")
    }
  ]
}) }}

  {{ govukButton({ text: "Save and return" }) }}
</form>

</div>
</div>
{% endblock %}

{% block pageScripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.querySelector('form');
  if (!form) return;

  form.addEventListener('submit', function () {
    const selected = document.querySelector('input[name="systype"]:checked');
    if (selected) {
      sessionStorage.setItem('systemDescription', selected.value);
    }
  });
});
</script>

{% endblock %}

