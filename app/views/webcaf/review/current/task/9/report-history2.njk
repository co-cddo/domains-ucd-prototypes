     <h2 class="govuk-heading-m govuk-!-margin-top-6">Create a new report version</h2>

    <p class="govuk-body">
      To create a new version of the report, you must first <strong>reopen the review</strong>.
      This allows you to edit outcome statuses, recommendations, and comments before creating the next version.
    </p>

    <form action="#" method="post">
      {{ govukButton({
        text: "Reopen review to create a new report version",
        classes: "govuk-button--warning"
      }) }}
    </form>

    <p class="govuk-body">
      <a href="/webcaf/review/current/my-account2" class="govuk-link">Return to My account</a>
    </p>


  </div>
</div>
{% endblock %}
