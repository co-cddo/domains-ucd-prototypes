{% extends "/layouts/review-v4.html" %}

{% block pageTitle %}
Report history – Independent Assurance Review
{% endblock %}

{% block beforeContent %}
  {% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

  {{ govukPhaseBanner({
    tag: {
      text: "prototype",
      classes: "govuk-tag--pink"
    },
    html: "This is not a full service. It is not production code and you might experience problems."
  }) }}

  {{ govukBreadcrumbs({
    items: [
      {
        text: "My account",
        href: "/webcaf/review/current/my-account2"
      },
      {
        text: "Report history"
      }
    ]
  }) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">

    <span class="govuk-caption-l">SYS-0001 Microsoft CS version 3 (CAF24092025FDMH)</span>
    <h1 class="govuk-heading-l">Report history</h1>

    <p class="govuk-body">
      This page shows all created versions of IAR for this system. You can view, download or use the latest review inputs to
      create a new report.
    </p>

    {{ govukInsetText({
      html: "Creating a new report will always use the most recent review data from WebCAF. Older report versions remain available for audit."
    }) }}

    {% from "govuk/components/table/macro.njk" import govukTable %}

    {{ govukTable({
      caption: "List of created reports",
      captionClasses: "govuk-table__caption--m",
      firstCellIsHeader: false,
      head: [
        { text: "Version" },
        { text: "Created on" },
        { text: "Created by Reviewer" },
        { text: "Status" },
        { text: "Actions" }
      ],
      rows: [
        [
          { text: "Version 4" },
          { text: "	14 February 2026 at 09:07" },
          { text: "Alex Morgan" },
          { html: "<strong class='govuk-tag govuk-tag--blue'>Current – with organisation</strong>" },
          {
            html:
              "<a class='govuk-link' href='#'>View report</a><br>" +
              "<a class='govuk-link' href='#'>Download (PDF)</a>" 
              
          }
        ],
        [
          { text: "Version 3" },
          { text: "30 November 2025 at 16:32" },
          { text: "Alex Morgan" },
          { html: "<strong class='govuk-tag govuk-tag--grey'>Superseded</strong>" },
          {
            html:
              "<a class='govuk-link' href='#'>View report</a><br>" +
              "<a class='govuk-link' href='#'>Download (PDF)</a>" 
              
          }
        ],
        [
          { text: "Version 2" },
          { text: "5 December 2025 at 10:15" },
          { text: "Alex Morgan" },
          { html: "<strong class='govuk-tag govuk-tag--grey'>Superseded</strong>" },
          {
            html:
              "<a class='govuk-link' href='#'>View report</a><br>" +
              "<a class='govuk-link' href='#'>Download (PDF)</a>"
          }
        ],
        [
          { text: "Version 1" },
          { text: "26 November 2025 at 16:03" },
          { text: "Alex Morgan" },
          { html: "<strong class='govuk-tag govuk-tag--grey'>Superseded</strong>" },
          {
            html:
              "<a class='govuk-link' href='#'>View report</a><br>" +
              "<a class='govuk-link' href='#'>Download (PDF)</a>"
          }
        ]
      ]
    }) }}

