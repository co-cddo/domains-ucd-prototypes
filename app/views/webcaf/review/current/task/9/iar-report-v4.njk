    <span class="gem-c-heading__xl govuk-heading-xl">
     GovAssure Independent Assurance Review Report (IARR) 
    </span>

     <span class="gem-c-inverse-header__subtext">
     <strong> Version 4 (Current – with organisation)</strong>
    </span>
    <br>
     <span class="gem-c-inverse-header__subtext">
      Updated {{ report.meta.reportUpdated }}
    </span>

  </div>
</header>

<section aria-label="Notice" class="govuk-notification-banner gem-c-notice govuk-!-margin-bottom-8" role="region">
  <div class="govuk-notification-banner__content">
    <span class="govuk-notification-banner__heading">
      This content is UK OFFICIAL-SENSITIVE.
    </span>
  </div>
</section>

<div id="contents">
  <div class="govuk-grid-row gem-print-columns-none">

    {# =========================================================
       Left navigation (keep your pattern)
       ========================================================= #}
    <div class="govuk-grid-column-one-quarter-from-desktop contents-list-container">
      <nav class="gem-c-contents-list govuk-!-margin-bottom-4" aria-label="Contents">
        <h2 class="gem-c-contents-list__title">Contents</h2>
        <ol class="gem-c-contents-list__list">

          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#executive-summary">Introduction</a>
          </li>
          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#exec-summary">Executive summary</a>
          </li>
          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#detail-summary">Detailed review of contributing outcomes</a>
          </li>

          {# remove broken 'Outcome status' and add objective anchors #}
          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#objective-a">Objective A</a>
          </li>
          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#objective-b">Objective B</a>
          </li>
          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#objective-c">Objective C</a>
          </li>
          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#objective-d">Objective D</a>
          </li>

          {# moved to end #}
          <li class="gem-c-contents-list__list-item">
            <a class="gem-c-contents-list__link" href="#full-recommendations-table">Full table of recommendations</a>
          </li>

        </ol>
      </nav>
    </div>

    {# =========================================================
       Main content
       ========================================================= #}
    <div class="govuk-grid-column-three-quarters-from-desktop">

      {# Executive summary (generic intro + lists) #}
      <h2 id="executive-summary" class="govuk-heading-xl">Introduction</h2>

      <p class="govuk-body">
        {{ report.executiveSummary.intro | safe }}

      </p>

      {# System overview (moved up) #}
      <h2 id="system-details" class="govuk-heading-m">System overview</h2>

      {{ govukSummaryList({
        classes: "govuk-summary-list",
        rows: [
          { key: { text: "System name" }, value: { text: report.meta.systemId ~ " " ~ report.meta.systemName } },
          { key: { text: "Reference number" }, value: { text: report.meta.reference } },
          { key: { text: "Organisation" }, value: { text: report.meta.organisation } },
          { key: { text: "System description" }, value: { text: report.systemDetails.description } },
          { key: { text: "Ownership" }, value: { text: report.systemDetails.ownership } },
          { key: { text: "Hosting" }, value: { text: report.systemDetails.hosting } },
          { key: { text: "Corporate services used" }, value: { text: report.systemDetails.corporateServices } },
          { key: { text: "Review type" }, value: { text: report.systemDetails.reviewType } },
          { key: { text: "CAF version" }, value: { text: report.systemDetails.cafVersion } },
          { key: { text: "Assigned target CAF profile" }, value: { text: report.systemDetails.cafProfile } }
        ]
      }) }}

      {# Period of review + company details #}

      <h2 id="period-of-review" class="govuk-heading-m">Period of review</h2>

      <p class="govuk-body">
        The independent assurance review was conducted between
        <strong>{{ report.periodOfReview.from }}</strong> and <strong>{{ report.periodOfReview.to }}</strong>.
      </p>

      <h3 class="govuk-heading-m">Independent assurance reviewer details</h3>
      {# Removing 2 keys
          { key: { text: "Company email address" }, value: { text: report.companyDetails.companyEmail } }
          
      #}
      {{ govukSummaryList({
        classes: "govuk-summary-list",
        rows: [
          { key: { text: "Company name" }, value: { text: report.companyDetails.companyName } },
          { key: { text: "Lead reviewer name" }, value: { text: "Mr. Isaac Johnson McAlister" } },
          { key: { text: "Lead reviewer email address" }, value: { text: "isaac.mcalister@company.com" } }
          
        ]
      }) }}


      {# Review method + evidence quality #}
      <h2 id="review-method" class="govuk-heading-m">Review method</h2>

      <p class="govuk-body">
        {{ report.reviewMethodIntro }}
      </p>
       <p class="govuk-body">
        {{ report.reviewMethod }}
      </p>

      
      {# EXEC SUMMARY: One combined outcome status table (all objectives)= #}
      <h2 id="exec-summary" class="govuk-heading-xl">Executive summary</h2>
      <h2 class="govuk-heading-m">Achievement status by contributing outcome</h2>
      <p>The table below shows the cyber security and resilience contributing outcome results against the target Government CAF profile.
      </p>

     {# EXEC SUMMARY: One combined outcome status table (all objectives)= #}
      <h2 id="exec-summary" class="govuk-heading-xl">Executive summary</h2>
      <h2 class="govuk-heading-m">Achievement status by contributing outcome</h2>
      <p>The table below shows the cyber security and resilience contributing outcome results against the target Government CAF profile.
      </p>

      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Outcome</th>
            <th scope="col" class="govuk-table__header">Self-assessment status</th>
            <th scope="col" class="govuk-table__header">Review status</th>
            <th scope="col" class="govuk-table__header">CAF Baseline profile</th>
          </tr>
        </thead>

        <tbody class="govuk-table__body">
          {% for obj in report.objectives %}
            {% for o in obj.outcomes %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ o.code }} {{ o.name }}</td>

                <td class="govuk-table__cell">
                  <strong class="govuk-tag {{ judgementTagClass[o.selfAssessment] }}">
                    {{ o.selfAssessment }}
                  </strong>
                </td>

                <td class="govuk-table__cell">
                  <strong class="govuk-tag {{ judgementTagClass[o.review] }}">
                    {{ o.review }}
                  </strong>
                </td>

                <td class="govuk-table__cell">
                  <strong class="govuk-tag {{ baselineTagClass[o.baseline] }}">
                    {{ o.baseline }}
                  </strong>
                </td>
              </tr>
            {% endfor %}
          {% endfor %}
        </tbody>
      </table>

      

        {# Areas of good practice and Areas for improvement  - broken by objetives (A-B) #}
        {% for obj in report.objectives %}

          <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">

          {# add anchor ids for navigation #}
          <h2 class="govuk-heading-l">
            Objective {{ obj.code }} — {{ obj.title }} 
          </h2>
          <h2 class="govuk-body">{{obj.subTitle }}</h2>

          {# Areas of good practice as a single text area (7–9 lines) #}
          <h3 class="govuk-heading-m">Areas of good practice</h3>
          <p class="govuk-body">
            {{ obj.goodPracticeText | replace("\n", "<br>") | safe }}
          </p>

          {# Areas for improvement as a block of text (not bullets) #}
          <h3 class="govuk-heading-m">Areas for improvement</h3>
          <p class="govuk-body">
            {{ obj.improvements | join("\n") | replace("\n", "<br>") | safe }}
          </p>
        {% endfor %}

     <h2 class="govuk-heading-l">Quality of the self-assessment and evidence</h2>
      <p class="govuk-body">
        {{ report.evidenceQuality.summaryHtml | safe }}
      </p>
      
      

      <p id="detail-summary"></p>
      {# Detailed review of contirubiting outcomes #}
      {% for obj in report.objectives %}
        <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">
      
        {# add anchor ids for navigation #}
        <h2 class="govuk-heading-xl">{{obj.detailHeading}}</h2>
        <h2 id="objective-{{ obj.code | lower }}" class="govuk-heading-l">
          Objective {{ obj.code }} — {{ obj.title }}
        </h2>

        {# INSERT: Outcome status table under each objective (same labels + same tag colours) #}
        <h3 class="govuk-heading-m">Outcome status</h3>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Outcome</th>
              <th scope="col" class="govuk-table__header">Self-assessment status</th>
              <th scope="col" class="govuk-table__header">Review status</th>
              <th scope="col" class="govuk-table__header">CAF Baseline profile</th>
            </tr>
          </thead>

          <tbody class="govuk-table__body">
            {% for o in obj.outcomes %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ o.code }} {{ o.name }}</td>

              <td class="govuk-table__cell">
                <strong class="govuk-tag {{ judgementTagClass[o.selfAssessment] }}">
                  {{ o.selfAssessment }}
                </strong>
              </td>

              <td class="govuk-table__cell">
                <strong class="govuk-tag {{ judgementTagClass[o.review] }}">
                  {{ o.review }}
                </strong>
              </td>

              <td class="govuk-table__cell">
                <strong class="govuk-tag {{ baselineTagClass[o.baseline] }}">
                  {{ o.baseline }}
                </strong>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>



  <h3 class="govuk-heading-m">Contributing outcomes</h3>

  {% for o in obj.outcomes %}
    {% call govukDetails({ summaryText: o.code ~ " — " ~ o.name }) %}

      <h5 class="govuk-heading-s">Review status</h5>

      <p class="govuk-body">
        <strong class="govuk-tag {{ judgementTagClass[o.review] }}">{{ o.review }}</strong>

        <span class="govuk-!-margin-left-2">
          {% if o.recommendations | length == 1 %}
            1 recommendation
            {# NEW: Required label where review is Not achieved and has recommendations #}
            {% if o.review == "Not achieved" and (o.recommendations | length > 0) %}
              <strong class="govuk-tag govuk-tag--grey govuk-!-margin-left-2">Required</strong>
            {% endif %}
          {% else %}
            {{ o.recommendations | length }} recommendations
          {% endif %}
        </span>
      </p>

      {% if o.recommendations | length > 0 %}
        <h4 class="govuk-heading-s">Recommendations for {{ o.code }}</h4>
        <ul class="govuk-list govuk-list--bullet">
          {% for recId in o.recommendations %}
            {% for r in report.topRecommendations %}
              {% if r.id == recId %}
                <li>
                  <strong>{{ r.id }} —</strong> {{ r.recommendation }}
                </li>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </ul>
      {% endif %}

      <h5 class="govuk-heading-s">Comment to support the review</h5>
      <p class="govuk-body">
        {{ o.summary }}
      </p>

      {# only show heading if comment exists #}
      {% if o.igpComment %}
        <h5 class="govuk-heading-s">Comments on individual IGPs</h5>
        <p class="govuk-body govuk-!-font-size-16">{{o.statement2}} </p>
        <p class="govuk-body">{{ o.igpComment }}</p>
      {% endif %}

    {% endcall %}
  {% endfor %}

{% endfor %}

       

      {# moved to end (body) #}
     <h2 id="full-recommendations-table" class="govuk-heading-l">Full table of recommendations</h2>

        {# =========================================================
          1) Priority recommendations
          This will be filted by 'not meeting the profile)
          ========================================================= #}
        <h3 class="govuk-heading-m">Priority recommendations</h3>
        <p>These recommendations address gaps identified for contributing outcomes where the target Government CAF profile has not been met. </p>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Rec number</th>
              <th scope="col" class="govuk-table__header">Objective / outcome</th>
              <th scope="col" class="govuk-table__header">Title</th>
              
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for r in report.topRecommendations %}

              {# determine if this recommendation truly requires the Required label #}
              {% set isPriorityRequired = false %}
              {% for obj in report.objectives %}
                {% for o in obj.outcomes %}
                  {% if o.code == r.outcome
                    and r.type == "Required"
                    and (o.review == "Not achieved" or o.review == "Partially achieved")
                    and (o.recommendations | length > 0) %}
                    {% set isPriorityRequired = true %}
                  {% endif %}
                {% endfor %}
              {% endfor %}

              {% if isPriorityRequired %}
                <tr class="govuk-table__row">
          <td class="govuk-table__cell"><strong>{{ r.id }}</strong></td>
          <td class="govuk-table__cell">Objective {{ r.objective }} / {{ r.outcome }}</td>
          <td class="govuk-table__cell">{{ r.issue }}</td>
          
        </tr>

        <tr class="govuk-table__row">
          <td class="govuk-table__cell" colspan="4">
            <details class="govuk-details" id="rec-{{ r.id }}">
              <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">
                  Recommendation detail
                </span>
              </summary>
              <div class="govuk-details__text">
                {{ r.recommendation | replace("\r\n", "\n") | replace("\n", "<br>") | safe }}
              </div>
            </details>
          </td>
        </tr>

              {% endif %}

            {% endfor %}
          </tbody>
        </table>

        {# =========================================================
          2) All other recommendations (everything else)
          ========================================================= #}
        <h3 class="govuk-heading-m">Other recommendations</h3>
        <p>These recommendations address gaps identified for contributing outcomes where the target Government CAF profile has been met. </p>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Rec number</th>
              <th scope="col" class="govuk-table__header">Objective / outcome</th>
              <th scope="col" class="govuk-table__header">Title</th>
              
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for r in report.topRecommendations %}

              {# exclude those already shown in Required table #}
              {% set isPriorityRequired = false %}
              {% for obj in report.objectives %}
                {% for o in obj.outcomes %}
                  {% if o.code == r.outcome
                    and r.type == "Required"
                    and (o.review == "Not achieved" or o.review == "Partially achieved")
                    and (o.recommendations | length > 0) %}
                    {% set isPriorityRequired = true %}
                  {% endif %}
                {% endfor %}
              {% endfor %}

              {% if not isPriorityRequired %}
                <tr class="govuk-table__row">
          <td class="govuk-table__cell"><strong>{{ r.id }}</strong></td>
          <td class="govuk-table__cell">Objective {{ r.objective }} / {{ r.outcome }}</td>
          <td class="govuk-table__cell">{{ r.issue }}</td>
          
        </tr>

        <tr class="govuk-table__row">
          <td class="govuk-table__cell" colspan="4">
            <details class="govuk-details" id="rec-{{ r.id }}">
              <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">
                  Recommendation detail
                </span>
              </summary>
              <div class="govuk-details__text">
               {{ r.recommendation | replace("\r\n", "\n") | replace("\n", "<br>") | safe }}
              </div>
            </details>
          </td>
        </tr>

              {% endif %}

            {% endfor %}
          </tbody>
        </table>


    </div>
  </div>
</div>

{% endblock %}
