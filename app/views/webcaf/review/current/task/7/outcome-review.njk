{% extends "layouts/main.html" %}

{% block pageTitle %}
Outcome-level summary review – CAF Assessment
{% endblock %}

{% block beforeContent %}
{{ govukBackLink({
  text: "Back to task list",
  href: "/webcaf/review/current/task-list"
}) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
<div class="govuk-grid-column-two-thirds">

<span class="govuk-caption-l">Microsoft CS version 3 (CAF24092025FDMH)</span>
<h1 class="govuk-heading-l">Outcome-level summary – Review and confirmation</h1>

<p class="govuk-body">
Review each outcome below.  
If you agree with the organisation’s self-assessment, select <strong>Confirm (agree)</strong>.  
Otherwise, choose a new status to reflect your independent review.
</p>
<style>
  .caf-outcome-table .govuk-table__cell {
    vertical-align: top;
    padding: 6px 8px;
  }
  .caf-outcome-table th:nth-child(1) {
    width: 40%;
  }
  .caf-outcome-table th:nth-child(2),
  .caf-outcome-table th:nth-child(3) {
    width: 30%;
  }
  .govuk-tag {
    white-space: nowrap; /* prevents multi-line tags */
  }
</style>


<form id="outcomeReviewForm">

<table class="govuk-table govuk-!-margin-bottom-2">
  <caption class="govuk-table__caption govuk-table__caption--m">List of outcome areas for review</caption>
  <thead class="govuk-table__head">
    <tr class="govuk-table__row">
      <th scope="col" class="govuk-table__header">Outcome area</th>
      <th scope="col" class="govuk-table__header">Self-assessment</th>
      <th scope="col" class="govuk-table__header">Your action</th>
    </tr>
  </thead>
  <tbody class="govuk-table__body">

    {% set outcomes = [
      { id: "A1a", title: "A1.a Board direction", self: "Not achieved" },
      { id: "A1b", title: "A1.b Roles and responsibilities", self: "Achieved" },
      { id: "A1c", title: "A1.c Decision-making", self: "Achieved" },
      { id: "A2a", title: "A2.a Risk Management Process", self: "Not achieved" },
      { id: "A2b", title: "A2.b Assurance", self: "Achieved" },
      { id: "A3a", title: "A3.a Asset management", self: "Achieved" },
      { id: "A4a", title: "A4.a Supply chain", self: "Achieved" },
      { id: "B1a", title: "B1.a Policy and process development", self: "Achieved" },
      { id: "B1b", title: "B1.b Policy and process implementation", self: "Achieved" },
      { id: "B2a", title: "B2.a Identity verification, authentication and authorisation", self: "Partially achieved" },
      { id: "B2b", title: "B2.b Device management", self: "Achieved" },
      { id: "B2c", title: "B2.c Privileged user management", self: "Achieved" },
      { id: "B2d", title: "B2.d Identity and access management (IdAM)", self: "Not achieved" },
      { id: "B3a", title: "B3.a Understanding data", self: "Achieved" },
      { id: "B3b", title: "B3.b Data in transit", self: "Achieved" },
      { id: "B3c", title: "B3.c Stored data", self: "Not achieved" },
      { id: "B3d", title: "B3.d Mobile data", self: "Achieved" },
      { id: "B3e", title: "B3.e Media equipment sanitisation", self: "Achieved" },
      { id: "B4a", title: "B4.a Secure by design", self: "Achieved" },
      { id: "B4b", title: "B4.b Secure configuration", self: "Achieved" },
      { id: "B4c", title: "B4.c Secure management", self: "Achieved" },
      { id: "B4d", title: "B4.d Vulnerability management", self: "Partially achieved" },
      { id: "B5a", title: "B5.a Resilience preparation", self: "Achieved" },
      { id: "B5b", title: "B5.b Design for resilience", self: "Achieved" },
      { id: "B5c", title: "B5.c Backups", self: "Achieved" },
      { id: "B6a", title: "B6.a Cyber security culture", self: "Partially achieved" },
      { id: "B6b", title: "B6.b Cyber security training", self: "Achieved" },
      { id: "C1a", title: "C1.a Monitoring coverage", self: "Achieved" },
      { id: "C1b", title: "C1.b Securing logs", self: "Not achieved" },
      { id: "C1c", title: "C1.c Generating alerts", self: "Achieved" },
      { id: "C1d", title: "C1.d Identifying security incidents", self: "Achieved" },
      { id: "C1e", title: "C1.e Monitoring tools and skills", self: "Not achieved" },
      { id: "C2a", title: "C2.a System abnormalities for attack detection", self: "Achieved" },
      { id: "C2b", title: "C2.b Proactive attack discovery", self: "Achieved" },
      { id: "D1a", title: "D1.a Response plan", self: "Achieved" },
      { id: "D1b", title: "D1.b Response and recovery capability", self: "Achieved" },
      { id: "D1c", title: "D1.c Testing and exercising", self: "Achieved" },
      { id: "D2a", title: "D2.a Incident root cause analysis", self: "Partially achieved" },
      { id: "D2b", title: "D2.b Using incidents to drive improvements", self: "Achieved" },
      { id: "D2c", title: "D2.c Testing and exercising", self: "Achieved" }
    ] %}

    {% for outcome in outcomes %}
    <tr class="govuk-table__row govuk-!-padding-1">
      <td class="govuk-table__cell"><strong>{{ outcome.title }}</strong></td>
      <td class="govuk-table__cell">
        {% if outcome.self == "Achieved" %}
          <strong class="govuk-tag govuk-tag--green">{{ outcome.self }}</strong>
        {% elseif outcome.self == "Partially achieved" %}
          <strong class="govuk-tag govuk-tag--yellow">{{ outcome.self }}</strong>
        {% else %}
          <strong class="govuk-tag govuk-tag--red">{{ outcome.self }}</strong>
          <br><br><strong>CAF profile</strong><br>
          <strong class="govuk-tag govuk-tag--grey govuk-!-margin-top-1">Not met</strong>
        {% endif %}
      </td>
      <td class="govuk-table__cell">
        {% set selectItems = [
          { text: "Select an option", value: "", selected: true },
          { text: "Confirm (agree)", value: "confirm" }
        ] %}

        {% if outcome.self != "Achieved" %}
          {% set selectItems = selectItems.concat([{ text: "Achieved", value: "Achieved" }]) %}
        {% endif %}
        {% if outcome.self != "Partially achieved" %}
          {% set selectItems = selectItems.concat([{ text: "Partially achieved", value: "Partially achieved" }]) %}
        {% endif %}
        {% if outcome.self != "Not achieved" %}
          {% set selectItems = selectItems.concat([{ text: "Not achieved", value: "Not achieved" }]) %}
        {% endif %}

        {{ govukSelect({
          id: outcome.id,
          name: outcome.id,
          label: { text: "Select action", classes: "govuk-visually-hidden" },
          classes: "govuk-!-margin-bottom-0",
          items: selectItems
        }) }}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<div class="govuk-button-group govuk-!-margin-top-6">
  {{ govukButton({ text: "Save and continue" }) }}
  {{ govukButton({ text: "Cancel", classes: "govuk-button--secondary", href: "/webcaf/review/current/task-list" }) }}
</div>

</form>

</div>
</div>

<script>
document.getElementById('outcomeReviewForm').addEventListener('submit', e => {
  e.preventDefault();

  const results = {};
  document.querySelectorAll('select').forEach(select => {
    const key = select.name;
    const value = select.value;
    if (value) results[key] = value;
  });

  sessionStorage.setItem('outcomeReview', JSON.stringify(results));
  sessionStorage.setItem('task7Status', 'completed');
  window.location.href = '/webcaf/review/current/task/7/outcome-check';
});
</script>

{% endblock %}
