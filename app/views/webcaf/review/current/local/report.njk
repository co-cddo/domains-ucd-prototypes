              {# ---------- SAFE helpers (no push) ---------- #}

        {# Worst-case judgement: Not achieved > Partially achieved > Achieved #}
        {% macro aggregateJudgementForPrinciple(obj, principle, fieldName) %}
          {% set hasNot = false %}
          {% set hasPartial = false %}

          {% for o in obj.outcomes %}
            {% if o.code.split(".")[0] == principle %}
              {% if o[fieldName] == "Not achieved" %}
                {% set hasNot = true %}
              {% elseif o[fieldName] == "Partially achieved" %}
                {% set hasPartial = true %}
              {% endif %}
            {% endif %}
          {% endfor %}

          {% if hasNot %}
            Not achieved
          {% elseif hasPartial %}
            Partially achieved
          {% else %}
            Achieved
          {% endif %}
        {% endmacro %}

        {# Baseline met mapping (handles Met/Not met and also Achieved if it appears) #}
        {% macro baselineIsMet(val) %}
          {% if val == "Met" or val == "Achieved" %}
            true
          {% else %}
            false
          {% endif %}
        {% endmacro %}

        {# Count outcomes + met/not met for a principle #}
        {% macro principleCounts(obj, principle) %}
          {# returns: "total|met|notmet" as text #}
          {% set total = 0 %}
          {% set met = 0 %}
          {% set notmet = 0 %}

          {% for o in obj.outcomes %}
            {% if o.code.split(".")[0] == principle %}
              {% set total = total + 1 %}
              {% set isMet = (baselineIsMet(o.baseline) | trim) %}
              {% if isMet == "true" %}
                {% set met = met + 1 %}
              {% else %}
                {% set notmet = notmet + 1 %}
              {% endif %}
            {% endif %}
          {% endfor %}

          {{ total ~ "|" ~ met ~ "|" ~ notmet }}
        {% endmacro %}

        {# Decide if we should render the principle row now (first appearance only) #}
        {% macro isFirstPrincipleOccurrence(obj, principle, currentIndex) %}
          {% set first = true %}
          {% for prev in obj.outcomes %}
            {% if loop.index0 < currentIndex %}
              {% if prev.code.split(".")[0] == principle %}
                {% set first = false %}
              {% endif %}
            {% endif %}
          {% endfor %}
          {{ first }}
        {% endmacro %}





      <h2 id="quality-evidence" class="govuk-heading-l">Executive summary NEW </h2>
  {# EXEC SUMMARY: Principle-level status tables (Review-driven baseline) #}
{% for obj in report.objectives %}

  <h2 id="objective-{{ obj.code | lower }}" class="govuk-heading-m">
    Objective {{ obj.code }} — {{ obj.title }}
  </h2>

  <table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row">
        <th scope="col" class="govuk-table__header">Principle</th>
        <th scope="col" class="govuk-table__header">Self-assessment status</th>
        <th scope="col" class="govuk-table__header">Review status</th>
        <th scope="col" class="govuk-table__header">CAF Baseline profile</th>
      </tr>
    </thead>

    <tbody class="govuk-table__body">
      {% for o in obj.outcomes %}
        {% set p = o.code.split(".")[0] %}
        {% set first = isFirstPrincipleOccurrence(obj, p, loop.index0) | trim %}

        {% if first == "true" %}

          {# Aggregate judgement tags for the principle (keep your existing helper) #}
          {% set aggSelf = aggregateJudgementForPrinciple(obj, p, "selfAssessment") | trim %}
          {% set aggReview = aggregateJudgementForPrinciple(obj, p, "review") | trim %}

          {# REVIEW-DRIVEN counts for baseline met/not met (NO push) #}
          {% set total = 0 %}
          {% set met = 0 %}
          {% set notmet = 0 %}

          {# Principle display name = first outcome name for that principle #}
          {% set principleName = "" %}

          {% for oo in obj.outcomes %}
            {% if oo.code.split(".")[0] == p %}
              {% set total = total + 1 %}

              {# baseline met only when REVIEW == Achieved #}
              {% if oo.review == "Achieved" %}
                {% set met = met + 1 %}
              {% else %}
                {% set notmet = notmet + 1 %}
              {% endif %}

              {% if principleName == "" %}
                {% set principleName = oo.name %}
              {% endif %}
            {% endif %}
          {% endfor %}

          {% set principleBaseline = "Not met" %}
          {% if met == total %}
            {% set principleBaseline = "Met" %}
          {% endif %}

          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <strong>{{ p }}</strong>
              {% if principleName %}
                <div class="govuk-body-s govuk-!-margin-top-1">{{ principleName }}</div>
              {% endif %}
            </td>

            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ judgementTagClass[aggSelf] }}">{{ aggSelf }}</strong>
            </td>

            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ judgementTagClass[aggReview] }}">{{ aggReview }}</strong>
              {# no counts here #}
            </td>

            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ baselineTagClass[principleBaseline] }}">
                {{ principleBaseline }}
              </strong>

              <div class="govuk-hint govuk-!-margin-top-1">
                {% if principleBaseline == "Not met" %}
                  {{ notmet }} out {{ total }} outcomes
                {% else %}
                  {{ met }} out {{ total }} outcomes
                {% endif %}
              </div>
            </td>
          </tr>

        {% endif %}
      {% endfor %}
    </tbody>
  </table>

{% endfor %}


      <h2 id="quality-evidence" class="govuk-heading-m">Quality and self-assessment evidence</h2>

      <p class="govuk-body">
        Overall evidence quality was assessed as <strong>{{ report.evidenceQuality.rating | lower }}</strong>.<br><br>
        {{ report.evidenceQuality.summaryHtml | safe }}
      </p>


      {# Per-objective drill-down sections (simple list view) #}
      {% from "govuk/components/details/macro.njk" import govukDetails %}

      {% for obj in report.objectives %}

        <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">

        {# add anchor ids for navigation #}
        <h2 id="objective-{{ obj.code | lower }}" class="govuk-heading-l">
          Objective {{ obj.code }} — {{ obj.title }}
        </h2>

        {# INSERT: Outcome status table under each objective (same labels + same tag colours) #}
        <h3 class="govuk-heading-m">Outcome status</h3>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Outcome</th>
              <th scope="col" class="govuk-table__header">Self-assessment status</th>
              <th scope="col" class="govuk-table__header">Review status</th>
              <th scope="col" class="govuk-table__header">CAF Baseline profile</th>
            </tr>
          </thead>

          <tbody class="govuk-table__body">
            {% for o in obj.outcomes %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ o.code }} {{ o.name }}</td>

              <td class="govuk-table__cell">
                <strong class="govuk-tag {{ judgementTagClass[o.selfAssessment] }}">
                  {{ o.selfAssessment }}
                </strong>
              </td>

              <td class="govuk-table__cell">
                <strong class="govuk-tag {{ judgementTagClass[o.review] }}">
                  {{ o.review }}
                </strong>
              </td>

              <td class="govuk-table__cell">
                <strong class="govuk-tag {{ baselineTagClass[o.baseline] }}">
                  {{ o.baseline }}
                </strong>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>

        {# Areas of good practice as a single text area (7–9 lines) #}
        <h3 class="govuk-heading-m">Areas of good practice</h3>
        <p class="govuk-body">
          {{ obj.goodPracticeText | replace("\n", "<br>") | safe }}
        </p>

        {# Areas for improvement as a block of text (not bullets) #}
        <h3 class="govuk-heading-m">Areas for improvement</h3>
        <p class="govuk-body">
          {{ obj.improvements | join("\n") | replace("\n", "<br>") | safe }}
        </p>

        <h3 class="govuk-heading-m">Outcome detail</h3>

        {% for o in obj.outcomes %}
          {% call govukDetails({ summaryText: o.code ~ " — " ~ o.name }) %}

            <h5 class="govuk-heading-s">Review status</h5>

            <p class="govuk-body">
              <strong class="govuk-tag {{ judgementTagClass[o.review] }}">{{ o.review }}</strong>

              <span class="govuk-!-margin-left-2">
                {% if o.recommendations | length == 1 %}
                  1 recommendation
                  {# NEW: Required label where review is Not achieved and has recommendations #}
                  {% if o.review == "Not achieved" and (o.recommendations | length > 0) %}
                    <strong class="govuk-tag govuk-tag--grey govuk-!-margin-left-2">Required</strong>
                  {% endif %}
                {% else %}
                  {{ o.recommendations | length }} recommendations
                {% endif %}
              </span>
            </p>

            {% if o.recommendations | length > 0 %}
              <h4 class="govuk-heading-s">Recommendations for {{ o.code }}</h4>
              <ul class="govuk-list govuk-list--bullet">
                {% for recId in o.recommendations %}
                  {% for r in report.topRecommendations %}
                    {% if r.id == recId %}
                      <li>
                        <strong>{{ r.id }} —</strong> {{ r.recommendation }}
                      </li>
                    {% endif %}
                  {% endfor %}
                {% endfor %}
              </ul>
            {% endif %}

            <h5 class="govuk-heading-s">Overall comment to support the review</h5>
            <p class="govuk-body">
              {{ o.summary }}
            </p>

            {# only show heading if comment exists #}
            {% if o.igpComment %}
              <h5 class="govuk-heading-s">Comments to the IGP statement</h5>
              <p class="govuk-body">{{ o.igpComment }}</p>
            {% endif %}

          {% endcall %}
        {% endfor %}

      {% endfor %}

      {# moved to end (body) #}
     <h2 id="full-recommendations-table" class="govuk-heading-l">Full table of recommendations</h2>

        {# =========================================================
          1) Required recommendations
          Only show rows that genuinely qualify for Required label
          ========================================================= #}
        <h3 class="govuk-heading-m">Required recommendations</h3>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Rec number</th>
              <th scope="col" class="govuk-table__header">Objective / outcome</th>
              <th scope="col" class="govuk-table__header">Title</th>
              
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for r in report.topRecommendations %}

              {# determine if this recommendation truly requires the Required label #}
              {% set isPriorityRequired = false %}
              {% for obj in report.objectives %}
                {% for o in obj.outcomes %}
                  {% if o.code == r.outcome
                    and r.type == "Required"
                    and (o.review == "Not achieved" or o.review == "Partially achieved")
                    and (o.recommendations | length > 0) %}
                    {% set isPriorityRequired = true %}
                  {% endif %}
                {% endfor %}
              {% endfor %}

              {% if isPriorityRequired %}
                <tr class="govuk-table__row">
          <td class="govuk-table__cell"><strong>{{ r.id }}</strong></td>
          <td class="govuk-table__cell">Objective {{ r.objective }} / {{ r.outcome }}</td>
          <td class="govuk-table__cell">{{ r.issue }}</td>
          
        </tr>

        <tr class="govuk-table__row">
          <td class="govuk-table__cell" colspan="4">
            <details class="govuk-details" id="rec-{{ r.id }}">
              <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">
                  Recommendation detail
                </span>
              </summary>
              <div class="govuk-details__text">
                {{ r.recommendation | replace("\r\n", "\n") | replace("\n", "<br>") | safe }}
              </div>
            </details>
          </td>
        </tr>

              {% endif %}

            {% endfor %}
          </tbody>
        </table>

        {# =========================================================
          2) All other recommendations (everything else)
          ========================================================= #}
        <h3 class="govuk-heading-m">Other recommendations</h3>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Rec number</th>
              <th scope="col" class="govuk-table__header">Objective / outcome</th>
              <th scope="col" class="govuk-table__header">Title</th>
              
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for r in report.topRecommendations %}

              {# exclude those already shown in Required table #}
              {% set isPriorityRequired = false %}
              {% for obj in report.objectives %}
                {% for o in obj.outcomes %}
                  {% if o.code == r.outcome
                    and r.type == "Required"
                    and (o.review == "Not achieved" or o.review == "Partially achieved")
                    and (o.recommendations | length > 0) %}
                    {% set isPriorityRequired = true %}
                  {% endif %}
                {% endfor %}
              {% endfor %}

              {% if not isPriorityRequired %}
                <tr class="govuk-table__row">
          <td class="govuk-table__cell"><strong>{{ r.id }}</strong></td>
          <td class="govuk-table__cell">Objective {{ r.objective }} / {{ r.outcome }}</td>
          <td class="govuk-table__cell">{{ r.issue }}</td>
          
        </tr>

        <tr class="govuk-table__row">
          <td class="govuk-table__cell" colspan="4">
            <details class="govuk-details" id="rec-{{ r.id }}">
              <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">
                  Recommendation detail
                </span>
              </summary>
              <div class="govuk-details__text">
               {{ r.recommendation | replace("\r\n", "\n") | replace("\n", "<br>") | safe }}
              </div>
            </details>
          </td>
        </tr>

              {% endif %}

            {% endfor %}
          </tbody>
        </table>


    </div>
  </div>
</div>

