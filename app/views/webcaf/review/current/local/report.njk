    { id: "REC-25", objective: "C", outcome: "C1.e", priority: "Quick win", type: "", issue: "Skills coverage evidence incomplete", recommendation: "Document monitoring roles/skills coverage and evidence handover and training for operational teams." },
    { id: "REC-26", objective: "C", outcome: "C2.a", priority: "Priority", type: "Required", issue: "Anomaly detection is not systematic and escalation is unclear", recommendation: "Define anomaly detection use-cases, escalation routes and evidence outcomes through regular reviews." },
    { id: "REC-27", objective: "C", outcome: "C2.b", priority: "Quick win", type: "", issue: "Proactive discovery outcomes not consistently documented", recommendation: "Record proactive discovery activities and evidence improvements driven by findings." }
  ]
} %}

